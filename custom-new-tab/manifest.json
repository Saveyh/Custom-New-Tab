{
  "manifest_version": 3,
  "name": "Custom New Tab",
  "description": "Minimalist new tab page with a customizable dashboard, local widgets, and smart search.",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "windows"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  }
}
