{
  "manifest_version": 3,
  "name": "Workspace New Tab",
  "description": "Page de nouvel onglet personnalisee avec liens rapides et projets reutilisables.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  }
}
